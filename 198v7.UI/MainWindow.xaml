<Window x:Class="_198v7.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="198v7" Height="660" Width="1100"
        Background="{StaticResource BrushBgPrimary}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Border CornerRadius="10"
            Background="{StaticResource BrushBgPrimary}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLEBAR -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrushBgTertiary}"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="10" Height="10"
                                CornerRadius="2"
                                Background="{StaticResource BrushAccent}"
                                Margin="0,0,8,0"/>
                        <TextBlock Text="198v7"
                                   Foreground="#EEEEEE"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <Border Background="{StaticResource BrushBgSecondary}"
                                CornerRadius="3" Padding="7,1">
                            <TextBlock Text="Ghost Spectre · Win11 25H2"
                                       Foreground="{StaticResource BrushAccent}"
                                       FontSize="9"
                                       FontFamily="Segoe UI"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="BtnMinimize"
                                Content="—"
                                Width="26" Height="18"
                                FontSize="10"
                                Foreground="#666666"
                                Background="#141820"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnMinimize_Click"/>
                        <Button x:Name="BtnMaximize"
                                Content="&#9633;"
                                Width="26" Height="18"
                                FontSize="10"
                                Foreground="#666666"
                                Background="#141820"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="4,0"
                                Click="BtnMaximize_Click"/>
                        <Button x:Name="BtnClose"
                                Content="✕"
                                Width="26" Height="18"
                                FontSize="10"
                                Foreground="#FF4040"
                                Background="#141820"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- BODY -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="46"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0"
                        Background="{StaticResource BrushBgTertiary}"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="0,0,1,0">
                    <StackPanel VerticalAlignment="Top" Margin="0,8,0,0">
                        <RadioButton Style="{StaticResource TabBtn}"
                                     GroupName="Nav"
                                     IsChecked="True"
                                     Click="Nav_Dashboard">
                            <TextBlock Text="⊞" FontSize="15"
                                       Foreground="{StaticResource BrushAccent}"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource TabBtn}"
                                     GroupName="Nav"
                                     Click="Nav_MyComputer">
                            <TextBlock Text="⬡" FontSize="15"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource TabBtn}"
                                     GroupName="Nav"
                                     Click="Nav_Cpu">
                            <TextBlock Text="▦" FontSize="15"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource TabBtn}"
                                     GroupName="Nav"
                                     Click="Nav_Gpu">
                            <TextBlock Text="▣" FontSize="15"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource TabBtn}"
                                     GroupName="Nav"
                                     Click="Nav_Ram">
                            <TextBlock Text="≡" FontSize="15"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource TabBtn}"
                                     GroupName="Nav"
                                     Click="Nav_Network">
                            <TextBlock Text="◎" FontSize="15"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource TabBtn}"
                                     GroupName="Nav"
                                     Click="Nav_Thermal">
                            <TextBlock Text="◈" FontSize="15"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource TabBtn}"
                                     GroupName="Nav"
                                     Click="Nav_Profiles">
                            <TextBlock Text="✦" FontSize="15"/>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <!-- MAIN CONTENT -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- TAB BAR -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushBgTertiary}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Margin="14,0">
                            <RadioButton x:Name="TabDashboard"
                                         Style="{StaticResource TabBtn}"
                                         GroupName="Tab"
                                         IsChecked="True"
                                         Content="Dashboard"
                                         Click="Nav_Dashboard"/>
                            <RadioButton x:Name="TabMyComputer"
                                         Style="{StaticResource TabBtn}"
                                         GroupName="Tab"
                                         Content="My Computer"
                                         Click="Nav_MyComputer"/>
                            <RadioButton x:Name="TabCpu"
                                         Style="{StaticResource TabBtn}"
                                         GroupName="Tab"
                                         Content="CPU Optimizer"
                                         Click="Nav_Cpu"/>
                            <RadioButton x:Name="TabGpu"
                                         Style="{StaticResource TabBtn}"
                                         GroupName="Tab"
                                         Content="GPU"
                                         Click="Nav_Gpu"/>
                            <RadioButton x:Name="TabRam"
                                         Style="{StaticResource TabBtn}"
                                         GroupName="Tab"
                                         Content="RAM"
                                         Click="Nav_Ram"/>
                            <RadioButton x:Name="TabNetwork"
                                         Style="{StaticResource TabBtn}"
                                         GroupName="Tab"
                                         Content="Network"
                                         Click="Nav_Network"/>
                            <RadioButton x:Name="TabThermal"
                                         Style="{StaticResource TabBtn}"
                                         GroupName="Tab"
                                         Content="Thermal"
                                         Click="Nav_Thermal"/>
                            <RadioButton x:Name="TabProfiles"
                                         Style="{StaticResource TabBtn}"
                                         GroupName="Tab"
                                         Content="Game Profiles"
                                         Click="Nav_Profiles"/>
                        </StackPanel>
                    </Border>

                    <!-- PAGE FRAME -->
                    <Frame Grid.Row="1"
                           x:Name="MainFrame"
                           NavigationUIVisibility="Hidden"
                           Background="{StaticResource BrushBgPrimary}"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>