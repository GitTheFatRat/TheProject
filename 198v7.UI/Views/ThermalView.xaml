<UserControl x:Class="_198v7.UI.Views.ThermalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushBgPrimary}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,10">
            <Border Style="{StaticResource MetricCard}" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="CPU S0" Style="{StaticResource MetricLabel}"/>
                    <TextBlock x:Name="TxtS0" Text="51°C"
                               Style="{StaticResource MetricValue}"
                               Foreground="{StaticResource BrushGood}"/>
                    <TextBlock Text="Margin: 25°C" Style="{StaticResource MetricSub}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="CPU S1" Style="{StaticResource MetricLabel}"/>
                    <TextBlock x:Name="TxtS1" Text="48°C"
                               Style="{StaticResource MetricValue}"
                               Foreground="{StaticResource BrushGood}"/>
                    <TextBlock Text="Margin: 28°C" Style="{StaticResource MetricSub}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="GPU" Style="{StaticResource MetricLabel}"/>
                    <TextBlock x:Name="TxtGpu" Text="67°C"
                               Style="{StaticResource MetricValue}"
                               Foreground="{StaticResource BrushWarn}"/>
                    <TextBlock Text="Fan: 68%" Style="{StaticResource MetricSub}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="FAN T400i" Style="{StaticResource MetricLabel}"/>
                    <TextBlock Text="1420 RPM"
                               Style="{StaticResource MetricValue}"
                               Foreground="{StaticResource BrushInfo}"/>
                    <TextBlock Text="Tản khí" Style="{StaticResource MetricSub}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelCard}" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="TEMPERATURE MONITOR" Style="{StaticResource MetricLabel}" Margin="0,0,0,8"/>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CPU Socket 0" Style="{StaticResource KvKey}"/>
                        <TextBlock x:Name="TxtS0b" Grid.Column="1" Text="51°C" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushGood}"/>
                    </Grid>
                    <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,3"/>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CPU Socket 1" Style="{StaticResource KvKey}"/>
                        <TextBlock x:Name="TxtS1b" Grid.Column="1" Text="48°C" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushGood}"/>
                    </Grid>
                    <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,3"/>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="TjMax Margin S0" Style="{StaticResource KvKey}"/>
                        <TextBlock Grid.Column="1" Text="25°C" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushGood}"/>
                    </Grid>
                    <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,3"/>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="RTX 3060 GPU" Style="{StaticResource KvKey}"/>
                        <TextBlock x:Name="TxtGpub" Grid.Column="1" Text="67°C" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushWarn}"/>
                    </Grid>
                    <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,3"/>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="VRAM" Style="{StaticResource KvKey}"/>
                        <TextBlock Grid.Column="1" Text="58°C" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushGood}"/>
                    </Grid>
                    <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,3"/>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Fan T400i" Style="{StaticResource KvKey}"/>
                        <TextBlock Grid.Column="1" Text="1420 RPM" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushInfo}"/>
                    </Grid>
                    <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,3"/>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="RAM DDR4" Style="{StaticResource KvKey}"/>
                        <TextBlock Grid.Column="1" Text="38°C" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushGood}"/>
                    </Grid>
                    <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,3"/>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="VRM (Huananzhi)" Style="{StaticResource KvKey}"/>
                        <TextBlock Grid.Column="1" Text="61°C" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushWarn}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelCard}" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="ALERT SETTINGS" Style="{StaticResource MetricLabel}" Margin="0,0,0,8"/>
                    <Border Background="#00E87A10" BorderBrush="#00E87A28"
                            BorderThickness="1" CornerRadius="5"
                            Padding="10,7" Margin="0,0,0,10">
                        <TextBlock Text="Tất cả nhiệt độ trong ngưỡng an toàn."
                                   Foreground="{StaticResource BrushAccent}"
                                   FontSize="9" TextWrapping="Wrap"/>
                    </Border>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Alert CPU &gt; 70°C" Style="{StaticResource KvKey}"/>
                            <TextBlock Text="Popup + âm thanh cảnh báo" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                    </Grid>
                    <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Alert GPU &gt; 80°C" Style="{StaticResource KvKey}"/>
                            <TextBlock Text="RTX 3060 thermal limit" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                    </Grid>
                    <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Auto-revert PL1 &gt; 72°C" Style="{StaticResource KvKey}"/>
                            <TextBlock Text="Safety guard tự động" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                    </Grid>
                    <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Log CSV theo giờ" Style="{StaticResource KvKey}"/>
                            <TextBlock Text="Lưu file để phân tích" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                    </Grid>
                    <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="DPC Latency Monitor" Style="{StaticResource KvKey}"/>
                            <TextBlock Text="Phát hiện stutter từ driver" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="False" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>