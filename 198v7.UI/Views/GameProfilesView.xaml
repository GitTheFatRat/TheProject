<UserControl x:Class="_198v7.UI.Views.GameProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushBgPrimary}">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Danh sách profiles -->
        <Border Grid.Column="0" Style="{StaticResource PanelCard}" Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="GAME PROFILES" Style="{StaticResource MetricLabel}" Margin="0,0,0,10"/>

                <!-- Profile Valorant -->
                <Border x:Name="ProfValorant"
                        Background="#00E87A08"
                        BorderBrush="{StaticResource BrushAccent}"
                        BorderThickness="1" CornerRadius="5"
                        Padding="10,8" Margin="0,0,0,4"
                        Cursor="Hand">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource BrushAccent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Valorant" Foreground="#CCCCCC" FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" Background="#00E87A14"
                                CornerRadius="3" Padding="5,1" VerticalAlignment="Center">
                            <TextBlock Text="ACTIVE" Foreground="{StaticResource BrushAccent}" FontSize="8"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Profile Cyberpunk -->
                <Border Background="Transparent" BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1" CornerRadius="5"
                        Padding="10,8" Margin="0,0,0,4" Cursor="Hand">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource BrushInfo}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Cyberpunk 2077" Foreground="#888888" FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" Background="{StaticResource BrushBgSecondary}"
                                CornerRadius="3" Padding="5,1" VerticalAlignment="Center">
                            <TextBlock Text="READY" Foreground="{StaticResource BrushTextDim}" FontSize="8"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Profile Elden Ring -->
                <Border Background="Transparent" BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1" CornerRadius="5"
                        Padding="10,8" Margin="0,0,0,4" Cursor="Hand">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource BrushWarn}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Elden Ring" Foreground="#888888" FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" Background="{StaticResource BrushBgSecondary}"
                                CornerRadius="3" Padding="5,1" VerticalAlignment="Center">
                            <TextBlock Text="READY" Foreground="{StaticResource BrushTextDim}" FontSize="8"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Profile League -->
                <Border Background="Transparent" BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1" CornerRadius="5"
                        Padding="10,8" Margin="0,0,0,4" Cursor="Hand">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="#888888" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="League of Legends" Foreground="#888888" FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" Background="{StaticResource BrushBgSecondary}"
                                CornerRadius="3" Padding="5,1" VerticalAlignment="Center">
                            <TextBlock Text="READY" Foreground="{StaticResource BrushTextDim}" FontSize="8"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Thêm profile -->
                <Border Background="Transparent" BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1" CornerRadius="5"
                        Padding="10,8" Cursor="Hand">
                    <TextBlock Text="+ Thêm profile mới..."
                               Foreground="{StaticResource BrushTextDim}"
                               FontSize="11" FontFamily="Segoe UI"/>
                </Border>

                <Button Content="AUTO-DETECT GAME"
                        Margin="0,10,0,0"
                        Background="#B07000" Foreground="#FFF0CC"
                        BorderThickness="0" Padding="0,8"
                        FontSize="11" FontWeight="Bold"
                        Cursor="Hand" Click="BtnAutoDetect_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- Chi tiết profile -->
        <Border Grid.Column="1" Style="{StaticResource PanelCard}">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <TextBlock Text="PROFILE: VALORANT"
                               Foreground="#EEEEEE"
                               FontSize="13" FontWeight="Bold"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                    <Border HorizontalAlignment="Right" Background="#00E87A14"
                            CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                        <TextBlock Text="ACTIVE" Foreground="{StaticResource BrushAccent}" FontSize="9"/>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="NUMA Pin → Node 0" Style="{StaticResource KvKey}"/>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="PL1 Boost 148W" Style="{StaticResource KvKey}"/>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="C-State C6/C7 Off" Style="{StaticResource KvKey}"/>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Low Latency GPU" Style="{StaticResource KvKey}"/>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Nagle Off" Style="{StaticResource KvKey}"/>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="BG Isolation Node 1" Style="{StaticResource KvKey}"/>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="IRQ Steer → S0" Style="{StaticResource KvKey}"/>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Timer Resolution 0.5ms" Style="{StaticResource KvKey}"/>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <Button Content="SAVE &amp; APPLY PROFILE"
                        Style="{StaticResource BtnApply}"
                        Margin="0,16,0,0"
                        Click="BtnSaveProfile_Click"/>
                <Button Content="RESTORE DEFAULTS"
                        Margin="0,6,0,0"
                        Background="#AA2020" Foreground="#FFE0E0"
                        BorderThickness="0" Padding="0,8"
                        FontSize="11" FontWeight="Bold" Cursor="Hand"
                        Click="BtnRestoreProfile_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>