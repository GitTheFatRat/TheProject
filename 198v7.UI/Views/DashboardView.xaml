<UserControl x:Class="_198v7.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushBgPrimary}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <UniformGrid Grid.Row="0" Columns="5" Margin="0,0,0,10">
            <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="CPU LOAD" Style="{StaticResource MetricLabel}"/>
                    <TextBlock x:Name="TxtCpuLoad" Text="38%"
                               Style="{StaticResource MetricValue}"
                               Foreground="{StaticResource BrushGood}"/>
                    <TextBlock Text="72 threads · 2 socket"
                               Style="{StaticResource MetricSub}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="RAM" Style="{StaticResource MetricLabel}"/>
                    <TextBlock x:Name="TxtRam" Text="28.4 GB"
                               Style="{StaticResource MetricValue}"
                               Foreground="{StaticResource BrushInfo}"/>
                    <TextBlock Text="/ 96GB · Node0: 64GB"
                               Style="{StaticResource MetricSub}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="CPU TEMP" Style="{StaticResource MetricLabel}"/>
                    <TextBlock x:Name="TxtCpuTemp" Text="51°C"
                               Style="{StaticResource MetricValue}"
                               Foreground="{StaticResource BrushGood}"/>
                    <TextBlock Text="TjMax 76°C · Margin 25°C"
                               Style="{StaticResource MetricSub}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="GPU TEMP" Style="{StaticResource MetricLabel}"/>
                    <TextBlock x:Name="TxtGpuTemp" Text="67°C"
                               Style="{StaticResource MetricValue}"
                               Foreground="{StaticResource BrushWarn}"/>
                    <TextBlock Text="RTX 3060 · Fan 68%"
                               Style="{StaticResource MetricSub}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="GAMING MODE" Style="{StaticResource MetricLabel}"/>
                    <TextBlock x:Name="TxtGamingMode" Text="ON"
                               Style="{StaticResource MetricValue}"
                               Foreground="{StaticResource BrushGood}"/>
                    <TextBlock Text="Profile: Valorant"
                               Style="{StaticResource MetricSub}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelCard}" Margin="0,0,8,0">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="SOCKET 0 — NODE 0 (64GB)"
                                   Style="{StaticResource MetricLabel}"
                                   VerticalAlignment="Center"/>
                        <Border HorizontalAlignment="Right" Background="#00E87A14"
                                CornerRadius="3" Padding="6,1">
                            <TextBlock Text="GAME ZONE"
                                       Foreground="{StaticResource BrushAccent}"
                                       FontSize="8"/>
                        </Border>
                    </Grid>
                    <ItemsControl x:Name="Socket0Bars">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                               Style="{StaticResource KvKey}" FontSize="10"/>
                                    <Border Grid.Column="1"
                                            Background="{StaticResource BrushBorder}"
                                            CornerRadius="2" Height="4"
                                            VerticalAlignment="Center" Margin="4,0">
                                        <Border CornerRadius="2" HorizontalAlignment="Left"
                                                Width="{Binding BarWidth}"
                                                Background="{Binding BarColor}"/>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding ValueText}"
                                               Style="{StaticResource KvVal}" FontSize="10"
                                               Foreground="{Binding BarColor}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelCard}" Margin="0,0,8,0">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="SOCKET 1 — NODE 1 (32GB)"
                                   Style="{StaticResource MetricLabel}"
                                   VerticalAlignment="Center"/>
                        <Border HorizontalAlignment="Right" Background="#4A9EFF14"
                                CornerRadius="3" Padding="6,1">
                            <TextBlock Text="BG ZONE"
                                       Foreground="{StaticResource BrushInfo}"
                                       FontSize="8"/>
                        </Border>
                    </Grid>
                    <ItemsControl x:Name="Socket1Bars">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                               Style="{StaticResource KvKey}" FontSize="10"/>
                                    <Border Grid.Column="1"
                                            Background="{StaticResource BrushBorder}"
                                            CornerRadius="2" Height="4"
                                            VerticalAlignment="Center" Margin="4,0">
                                        <Border CornerRadius="2" HorizontalAlignment="Left"
                                                Width="{Binding BarWidth}"
                                                Background="{Binding BarColor}"/>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding ValueText}"
                                               Style="{StaticResource KvVal}" FontSize="10"
                                               Foreground="{Binding BarColor}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="2" Margin="0,0,0,0">
                <Border Style="{StaticResource PanelCard}" Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="SYSTEM STATUS"
                                       Style="{StaticResource MetricLabel}"
                                       VerticalAlignment="Center"/>
                            <Border HorizontalAlignment="Right" Background="#00E87A14"
                                    CornerRadius="3" Padding="6,1">
                                <TextBlock Text="ALL CLEAR"
                                           Foreground="{StaticResource BrushAccent}"
                                           FontSize="8"/>
                            </Border>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Throttle" Style="{StaticResource KvKey}"/>
                            <TextBlock Grid.Column="1" Text="None"
                                       Style="{StaticResource KvVal}"
                                       Foreground="{StaticResource BrushGood}"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="NUMA pin" Style="{StaticResource KvKey}"/>
                            <TextBlock Grid.Column="1" Text="Active"
                                       Style="{StaticResource KvVal}"
                                       Foreground="{StaticResource BrushGood}"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="QPI traffic" Style="{StaticResource KvKey}"/>
                            <TextBlock x:Name="TxtQpi" Grid.Column="1" Text="2.1 GB/s"
                                       Style="{StaticResource KvVal}"
                                       Foreground="{StaticResource BrushGood}"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="PL1 / PL2" Style="{StaticResource KvKey}"/>
                            <TextBlock Grid.Column="1" Text="148W/180W"
                                       Style="{StaticResource KvVal}"
                                       Foreground="{StaticResource BrushWarn}"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="AVX downbin" Style="{StaticResource KvKey}"/>
                            <TextBlock Grid.Column="1" Text="-2 bins S1"
                                       Style="{StaticResource KvVal}"
                                       Foreground="{StaticResource BrushWarn}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelCard}">
                    <StackPanel>
                        <TextBlock Text="QUICK ACTIONS"
                                   Style="{StaticResource MetricLabel}"
                                   Margin="0,0,0,8"/>
                        <Button x:Name="BtnGamingMode"
                                Content="GAMING MODE ON"
                                Style="{StaticResource BtnApply}"
                                Click="BtnGamingMode_Click"/>
                        <Button x:Name="BtnRestore"
                                Content="RESTORE DEFAULTS"
                                Margin="0,6,0,0"
                                Foreground="#FFF0CC"
                                BorderThickness="0"
                                Padding="0,8"
                                FontSize="11" FontWeight="Bold"
                                Cursor="Hand"
                                Click="BtnRestore_Click">
                            <Button.Background>
                                <SolidColorBrush Color="#B07000"/>
                            </Button.Background>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>