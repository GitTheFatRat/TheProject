<UserControl x:Class="_198v7.UI.Views.CpuOptimizerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushBgPrimary}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ROW 1: 5 metrics -->
            <UniformGrid Grid.Row="0" Columns="5" Margin="0,0,0,10">
                <Border Style="{StaticResource MetricCard}" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="S0 FREQUENCY" Style="{StaticResource MetricLabel}"/>
                        <TextBlock x:Name="TxtF0" Text="3.2 GHz"
                               Style="{StaticResource MetricValue}"
                               Foreground="{StaticResource BrushGood}"/>
                        <TextBlock Text="Max single-core: 3.4" Style="{StaticResource MetricSub}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="S1 FREQUENCY" Style="{StaticResource MetricLabel}"/>
                        <TextBlock x:Name="TxtF1" Text="3.0 GHz"
                               Style="{StaticResource MetricValue}"
                               Foreground="{StaticResource BrushGood}"/>
                        <TextBlock Text="All-core turbo" Style="{StaticResource MetricSub}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="PL1 / PL2" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="148W / 180W"
                               Style="{StaticResource MetricValue}"
                               Foreground="{StaticResource BrushWarn}"/>
                        <TextBlock Text="Default: 135 / 165W" Style="{StaticResource MetricSub}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="THROTTLE" Style="{StaticResource MetricLabel}"/>
                        <TextBlock x:Name="TxtThrottle" Text="None"
                               Style="{StaticResource MetricValue}"
                               Foreground="{StaticResource BrushGood}"/>
                        <TextBlock Text="No limit active" Style="{StaticResource MetricSub}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Text="S0 vs S1 DELTA" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="200 MHz"
                               Style="{StaticResource MetricValue}"
                               Foreground="{StaticResource BrushWarn}"/>
                        <TextBlock Text="Slight imbalance" Style="{StaticResource MetricSub}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ROW 2: Core bars + MSR + NUMA -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Socket 0 cores -->
                <Border Grid.Column="0" Style="{StaticResource PanelCard}" Margin="0,0,6,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="SOCKET 0 — PER-CORE LOAD"
                                   Style="{StaticResource MetricLabel}"
                                   VerticalAlignment="Center"/>
                            <Border HorizontalAlignment="Right" Background="#00E87A14"
                                CornerRadius="3" Padding="5,1">
                                <TextBlock Text="18 cores" Foreground="{StaticResource BrushAccent}" FontSize="8"/>
                            </Border>
                        </Grid>
                        <ItemsControl x:Name="CpuS0Bars">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="30"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" Style="{StaticResource KvKey}" FontSize="10"/>
                                        <Border Grid.Column="1" Background="{StaticResource BrushBorder}"
                                            CornerRadius="2" Height="4" VerticalAlignment="Center" Margin="4,0">
                                            <Border CornerRadius="2" HorizontalAlignment="Left"
                                                Width="{Binding BarWidth}" Background="{Binding BarColor}"/>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding ValueText}"
                                               Style="{StaticResource KvVal}" FontSize="10"
                                               Foreground="{Binding BarColor}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Socket 1 cores -->
                <Border Grid.Column="1" Style="{StaticResource PanelCard}" Margin="0,0,6,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="SOCKET 1 — PER-CORE LOAD"
                                   Style="{StaticResource MetricLabel}"
                                   VerticalAlignment="Center"/>
                            <Border HorizontalAlignment="Right" Background="#4A9EFF14"
                                CornerRadius="3" Padding="5,1">
                                <TextBlock Text="18 cores" Foreground="{StaticResource BrushInfo}" FontSize="8"/>
                            </Border>
                        </Grid>
                        <ItemsControl x:Name="CpuS1Bars">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="30"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" Style="{StaticResource KvKey}" FontSize="10"/>
                                        <Border Grid.Column="1" Background="{StaticResource BrushBorder}"
                                            CornerRadius="2" Height="4" VerticalAlignment="Center" Margin="4,0">
                                            <Border CornerRadius="2" HorizontalAlignment="Left"
                                                Width="{Binding BarWidth}" Background="{Binding BarColor}"/>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding ValueText}"
                                               Style="{StaticResource KvVal}" FontSize="10"
                                               Foreground="{Binding BarColor}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Throttle Detector + MSR -->
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource PanelCard}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="THROTTLE DETECTOR" Style="{StaticResource MetricLabel}" Margin="0,0,0,8"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Thermal S0" Style="{StaticResource KvKey}"/>
                                <TextBlock Grid.Column="1" Text="Clear" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushGood}"/>
                            </Grid>
                            <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,3"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Thermal S1" Style="{StaticResource KvKey}"/>
                                <TextBlock Grid.Column="1" Text="Clear" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushGood}"/>
                            </Grid>
                            <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,3"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="PL1/PL2" Style="{StaticResource KvKey}"/>
                                <TextBlock Grid.Column="1" Text="Clear" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushGood}"/>
                            </Grid>
                            <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,3"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="PROCHOT" Style="{StaticResource KvKey}"/>
                                <TextBlock Grid.Column="1" Text="Clear" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushGood}"/>
                            </Grid>
                            <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,3"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="AVX downbin S1" Style="{StaticResource KvKey}"/>
                                <TextBlock Grid.Column="1" Text="-2 bins" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushWarn}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource PanelCard}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="MSR REGISTERS" Style="{StaticResource MetricLabel}" Margin="0,0,0,8"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="PL1 S0/S1" Style="{StaticResource KvKey}"/>
                                    <TextBlock Text="MSR 0x610" Foreground="{StaticResource BrushTextDim}" FontSize="8" FontFamily="Consolas"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="148W" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushWarn}"/>
                            </Grid>
                            <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,3"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Turbo 1C" Style="{StaticResource KvKey}"/>
                                    <TextBlock Text="MSR 0x1AD" Foreground="{StaticResource BrushTextDim}" FontSize="8" FontFamily="Consolas"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="34×=3.4" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushGood}"/>
                            </Grid>
                            <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,3"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="TjMax" Style="{StaticResource KvKey}"/>
                                    <TextBlock Text="MSR 0x1A2" Foreground="{StaticResource BrushTextDim}" FontSize="8" FontFamily="Consolas"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="76°C" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushInfo}"/>
                            </Grid>
                            <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,3"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Speed Shift" Style="{StaticResource KvKey}"/>
                                    <TextBlock Text="MSR 0x774" Foreground="{StaticResource BrushTextDim}" FontSize="8" FontFamily="Consolas"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="N/A" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushDanger}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ROW 3: Tweaks -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- General CPU Tweaks -->
                <Border Grid.Column="0" Style="{StaticResource PanelCard}" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="GENERAL CPU TWEAKS" Style="{StaticResource MetricLabel}" Margin="0,0,0,8"/>
                        <TextBlock Text="POWER &amp; CLOCK" Style="{StaticResource SectionLabel}"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Ultimate Performance Plan" Style="{StaticResource KvKey}"/>
                                <TextBlock Text="Max boost, tắt throttling" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Disable Core Parking" Style="{StaticResource KvKey}"/>
                                <TextBlock Text="Giữ 72 luồng sẵn sàng" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="PL1 Boost (148W)" Style="{StaticResource KvKey}"/>
                                <TextBlock Text="+13W so với mặc định" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="C-STATE" Style="{StaticResource SectionLabel}"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Tắt C6 / C7" Style="{StaticResource KvKey}"/>
                                <TextBlock Text="MSR 0xE2 — giảm wake latency" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Giữ C1E" Style="{StaticResource KvKey}"/>
                                <TextBlock Text="Cân bằng nhiệt khi idle" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="SAFETY" Style="{StaticResource SectionLabel}"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Auto-revert T &gt; 72°C" Style="{StaticResource KvKey}"/>
                                <TextBlock Text="Tự động hoàn tác khi quá nhiệt" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="PROCHOT Offset +3°C" Style="{StaticResource KvKey}"/>
                                <TextBlock Text="Chỉ bật khi tản nhiệt tốt" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="False" VerticalAlignment="Center"/>
                        </Grid>
                        <Button Content="APPLY CPU TWEAKS" Style="{StaticResource BtnApply}"
                            Margin="0,10,0,0" Click="BtnApplyCpu_Click"/>
                    </StackPanel>
                </Border>

                <!-- NUMA & Scheduler -->
                <Border Grid.Column="1" Style="{StaticResource PanelCard}" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="NUMA &amp; SCHEDULER" Style="{StaticResource MetricLabel}" Margin="0,0,0,8"/>
                        <TextBlock Text="NUMA TOPOLOGY" Style="{StaticResource SectionLabel}"/>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Game → Node" Style="{StaticResource KvKey}"/>
                            <TextBlock Grid.Column="1" Text="0 (optimal)" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushGood}"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,3"/>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Node 0 BW" Style="{StaticResource KvKey}"/>
                            <TextBlock Grid.Column="1" Text="42 GB/s" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushInfo}"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,3"/>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Node 1 BW" Style="{StaticResource KvKey}"/>
                            <TextBlock Grid.Column="1" Text="24 GB/s" Style="{StaticResource KvVal}" Foreground="{StaticResource BrushWarn}"/>
                        </Grid>
                        <TextBlock Text="PROCESS PINNING" Style="{StaticResource SectionLabel}"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Game pinned → Node 0" Style="{StaticResource KvKey}"/>
                                <TextBlock Text="VirtualAllocExNuma" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="BG tasks → Node 1" Style="{StaticResource KvKey}"/>
                                <TextBlock Text="Job Objects isolation" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="IRQ steer → Socket 0" Style="{StaticResource KvKey}"/>
                                <TextBlock Text="GPU &amp; NIC interrupt" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="THREAD SCHEDULER" Style="{StaticResource SectionLabel}"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Game → Above Normal" Style="{StaticResource KvKey}"/>
                                <TextBlock Text="SetPriorityClass" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Win32PrioritySeparation" Style="{StaticResource KvKey}"/>
                                <TextBlock Text="Foreground boost hex 26" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Button Content="APPLY NUMA SETTINGS" Style="{StaticResource BtnApply}"
                            Margin="0,10,0,0" Click="BtnApplyNuma_Click"/>
                    </StackPanel>
                </Border>

                <!-- Ghost Spectre tweaks -->
                <Border Grid.Column="2" Style="{StaticResource PanelCard}">
                    <StackPanel>
                        <TextBlock Text="GHOST SPECTRE 25H2" Style="{StaticResource MetricLabel}" Margin="0,0,0,8"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="WMI Fallback P/Invoke" Style="{StaticResource KvKey}"/>
                                <TextBlock Text="Tự động nếu WMI bị remove" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Timer Resolution 0.5ms" Style="{StaticResource KvKey}"/>
                                <TextBlock Text="Verify trước khi patch" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="EcoQoS BG Tasks" Style="{StaticResource KvKey}"/>
                                <TextBlock Text="Win11 25H2 Efficiency Mode" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Core Isolation (4 cores)" Style="{StaticResource KvKey}"/>
                                <TextBlock Text="Quiet cores cho game thread" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="False" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Thread Migration Limit" Style="{StaticResource KvKey}"/>
                                <TextBlock Text="Ghim game thread ổn định" Foreground="{StaticResource BrushTextDim}" FontSize="9"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="False" VerticalAlignment="Center"/>
                        </Grid>
                        <Button Content="APPLY SCHEDULER" Style="{StaticResource BtnApply}"
                            Margin="0,10,0,0" Click="BtnApplyScheduler_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>